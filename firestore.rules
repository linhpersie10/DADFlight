rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isEmergencySuperAdmin() {
      return request.auth != null && (request.auth.token.email == "linh.persie.10@gmail.com" || request.auth.token.isSuperadmin == true);
    }

    function isEmergencySystemActive() {
      let path = /databases/$(database)/documents/system_settings/maintenance;
      return !exists(path) || get(path).data.isLocked == false;
    }

    match /system_settings/maintenance {
      allow read: if true;
      allow write: if isEmergencySuperAdmin();
    }

    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/PKT_DAD_users/$(userId)).data;
    }

    function isApproved(userId) {
      let data = getUserData(userId);
      return data.isApproved == true || data.status == 'approved';
    }

    function isAdmin(userId) {
      let data = getUserData(userId);
      return data.isAdmin == true || data.role == 'admin' || data.role == 'superadmin';
    }

    function isSuperadmin(userId) {
      let data = getUserData(userId);
      return data.isSuperadmin == true || data.role == 'superadmin';
    }

    // PKT_DAD_users rules
    match /PKT_DAD_users/{userId} {
      // User can read their own profile, Admins/Superadmins can read all profiles
      allow read: if isEmergencySuperAdmin() || ((isOwner(userId) || (isSignedIn() && (isAdmin(request.auth.uid) || isSuperadmin(request.auth.uid)))) && isEmergencySystemActive());

      // Allow users to create their own profile initially
      allow create: if isEmergencySuperAdmin() || ((isOwner(userId) &&
        // Case 1: Standard new user creation
        (
          (
            request.resource.data.role == (request.resource.data.email.lower() == 'linh.persie.10@gmail.com' ? 'superadmin' : 'user') &&
            request.resource.data.status == (request.resource.data.email.lower() == 'linh.persie.10@gmail.com' ? 'approved' : 'pending') &&
            request.resource.data.isApproved == (request.resource.data.email.lower() == 'linh.persie.10@gmail.com') &&
            request.resource.data.isAdmin == (request.resource.data.email.lower() == 'linh.persie.10@gmail.com') &&
            request.resource.data.isSuperadmin == (request.resource.data.email.lower() == 'linh.persie.10@gmail.com')
          ) ||
          // Case 2: Self-migration from a duplicate user profile with matching email
          (
            request.resource.data.migratedFrom != null &&
            exists(/databases/$(database)/documents/PKT_DAD_users/$(request.resource.data.migratedFrom)) &&
            get(/databases/$(database)/documents/PKT_DAD_users/$(request.resource.data.migratedFrom)).data.email.lower() == request.auth.token.email.lower() &&
            request.resource.data.role == get(/databases/$(database)/documents/PKT_DAD_users/$(request.resource.data.migratedFrom)).data.role &&
            request.resource.data.status == get(/databases/$(database)/documents/PKT_DAD_users/$(request.resource.data.migratedFrom)).data.status &&
            request.resource.data.isApproved == get(/databases/$(database)/documents/PKT_DAD_users/$(request.resource.data.migratedFrom)).data.isApproved &&
            request.resource.data.isAdmin == get(/databases/$(database)/documents/PKT_DAD_users/$(request.resource.data.migratedFrom)).data.isAdmin &&
            request.resource.data.isSuperadmin == get(/databases/$(database)/documents/PKT_DAD_users/$(request.resource.data.migratedFrom)).data.isSuperadmin
          )
        ) &&
        request.resource.data.email.lower() == request.auth.token.email.lower()) && isEmergencySystemActive());

      // Allow updates:
      // 1. Superadmin can update anything
      // 2. Admin can update non-superadmins
      // 3. User can update their own non-security profile info (requestedApps, hasPin, displayName, photoURL, fullName, updatedAt)
      allow update: if isEmergencySuperAdmin() || (((
        isSignedIn() && (
          isSuperadmin(request.auth.uid) ||
          (isAdmin(request.auth.uid) && resource.data.role != 'superadmin') ||
          (
            isOwner(userId) &&
            request.resource.data.role == resource.data.role &&
            request.resource.data.status == resource.data.status &&
            request.resource.data.isApproved == resource.data.isApproved &&
            request.resource.data.isAdmin == resource.data.isAdmin &&
            request.resource.data.isSuperadmin == resource.data.isSuperadmin
          )
        )
      )) && isEmergencySystemActive());

      // Allow delete for:
      // 1. Superadmins to clean up obsolete/duplicate profiles
      // 2. Users to delete their own old/duplicate profiles (based on matching email)
      allow delete: if isEmergencySuperAdmin() || (((
        (isSignedIn() && isSuperadmin(request.auth.uid)) ||
        (isSignedIn() && resource.data.email.lower() == request.auth.token.email.lower())
      )) && isEmergencySystemActive());

      // Subcollection private (only contains PIN document)
      match /private/{document=**} {
        allow read, write: if isEmergencySuperAdmin() || ((isOwner(userId)) && isEmergencySystemActive());
      }
    }

    // PKT_DAD_datasets rules
    match /PKT_DAD_datasets/{datasetId} {
      allow read: if isEmergencySuperAdmin() || ((isSignedIn() && (isApproved(request.auth.uid) || isOwner(request.auth.uid))) && isEmergencySystemActive());
      allow write: if isEmergencySuperAdmin() || ((isSignedIn() && (isAdmin(request.auth.uid) || isSuperadmin(request.auth.uid))) && isEmergencySystemActive());

      // Subcollection legs (legacy compatibility)
      match /legs/{legId} {
        allow read: if isEmergencySuperAdmin() || ((isSignedIn() && (isApproved(request.auth.uid) || isOwner(request.auth.uid))) && isEmergencySystemActive());
        allow write: if isEmergencySuperAdmin() || ((isSignedIn() && (isAdmin(request.auth.uid) || isSuperadmin(request.auth.uid))) && isEmergencySystemActive());
      }
    }

    // PKT_DAD_dataset_records rules
    match /PKT_DAD_dataset_records/{datasetId} {
      allow read: if isEmergencySuperAdmin() || ((isSignedIn() && (isApproved(request.auth.uid) || isOwner(request.auth.uid))) && isEmergencySystemActive());
      allow write: if isEmergencySuperAdmin() || ((isSignedIn() && (isAdmin(request.auth.uid) || isSuperadmin(request.auth.uid))) && isEmergencySystemActive());
    }
  }
}
